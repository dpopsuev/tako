# RCA Engine — fold-generated circuit MCP server.
#
# Prerequisites: origami fold must have built the binary first:
#   cd ~/Workspace/asterisk && origami fold
#
# Build: docker build -t origami-rca -f deploy/Dockerfile.rca ~/Workspace/asterisk
# Run:   docker run -p 9200:9200 origami-rca --port 9200 --domain-endpoint http://domain:9300/mcp

FROM gcr.io/distroless/static-debian12
COPY bin/asterisk /rca-serve
ENTRYPOINT ["/rca-serve"]
EXPOSE 9200
