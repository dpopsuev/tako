FROM golang:1.25 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /origami ./cmd/origami

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /origami /usr/local/bin/origami
EXPOSE 9100
ENTRYPOINT ["origami", "serve"]
CMD ["--circuit", "sdlc", "--port", "9100"]
